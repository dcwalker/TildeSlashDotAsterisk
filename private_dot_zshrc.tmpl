# Check if oh-my-zsh is installed
if [ -d "$HOME/.oh-my-zsh" ]; then
  # ========================================
  # Oh My Zsh Configuration
  # ========================================
  
  # Path to your Oh My Zsh installation.
  export ZSH="$HOME/.oh-my-zsh"
  
  # Set theme
  ZSH_THEME="robbyrussell"
  
  # Which plugins would you like to load?
  plugins=(git yarn nvm npm macos colored-man-pages chezmoi zsh-syntax-highlighting)

  # Disable plugin and core library aliases (we define our own in shell_common)
  zstyle ':omz:plugins:*' aliases no
  zstyle ':omz:lib:*' aliases no

  source $ZSH/oh-my-zsh.sh

  # Cache dir for PR number lookups
  _GIT_PR_CACHE_DIR="${TMPDIR:-/tmp}/zsh_git_pr_cache"

  # Look up the open PR URL for a branch (cached, refreshed in background).
  # Writes the full GitHub PR URL or "" to a per-branch cache file; reads stale
  # value while gh runs so the prompt never blocks on a network call.
  git_pr_url() {
    local branch="$1"
    [[ -z "$branch" ]] && return

    # Only try for GitHub remotes
    local remote_url
    remote_url=$(command git remote get-url origin 2>/dev/null)
    [[ "$remote_url" != *github.com* ]] && return

    command -v gh > /dev/null 2>&1 || return

    mkdir -p "$_GIT_PR_CACHE_DIR"
    local cache_key="${branch//\//_}"
    local cache_file="$_GIT_PR_CACHE_DIR/$cache_key"
    local cache_ttl=60

    local cache_age=99999
    if [[ -f "$cache_file" ]]; then
      cache_age=$(( $(date +%s) - $(stat -f %m "$cache_file" 2>/dev/null || echo 0) ))
    fi

    if [[ $cache_age -ge $cache_ttl ]]; then
      # Refresh in the background; return stale value this render
      (
        local pr_url
        pr_url=$(gh pr view "$branch" --json url --jq '.url' 2>/dev/null)
        printf '%s' "$pr_url" > "$cache_file"
      ) &!
    fi

    [[ -f "$cache_file" ]] && cat "$cache_file"
  }

  # Custom git prompt with truncated branch name (max 50 chars)
  git_prompt_info() {
    local ref
    ref=$(command git symbolic-ref HEAD 2> /dev/null) || \
    ref=$(command git rev-parse --short HEAD 2> /dev/null) || return 0

    local full_branch="${ref#refs/heads/}"
    local branch="$full_branch"
    if [[ ${#branch} -gt 50 ]]; then
      branch="${branch:0:30}..."
    fi

    local esc=$'\e' bel=$'\a'

    # Wrap branch name in OSC 8 link to GitHub branch page if applicable
    local branch_display="$branch"
    local remote_url
    remote_url=$(command git remote get-url origin 2>/dev/null)
    if [[ "$remote_url" == *github.com* ]]; then
      local repo_url="${remote_url%.git}"
      repo_url="${repo_url/git@github.com:/https://github.com/}"
      local branch_url="${repo_url}/tree/${full_branch}"
      branch_display="%{${esc}]8;;${branch_url}${bel}%}${branch}%{${esc}]8;;${bel}%}"
    fi

    local pr_url
    pr_url=$(git_pr_url "$full_branch")
    local pr_suffix=""
    if [[ "$pr_url" == https://* ]]; then
      local pr_num="#${pr_url##*/}"
      pr_suffix="%{${esc}]8;;${pr_url}${bel}%}%{$fg[cyan]%}[${pr_num}]%{$reset_color%}%{${esc}]8;;${bel}%}"
    fi

    echo "
${ZSH_THEME_GIT_PROMPT_PREFIX}${branch_display}$(parse_git_dirty)${ZSH_THEME_GIT_PROMPT_SUFFIX}${pr_suffix}"
  }
  
  # Enable prompt substitution
  setopt PROMPT_SUBST
  
  # Function to get truncated directory
  prompt_dir() {
    local dir="${PWD/#$HOME/~}"
    if [[ ${#dir} -gt 35 ]]; then
      echo "...${dir: -32}"
    else
      echo "$dir"
    fi
  }
  
  # Customize prompt to add username@machine while keeping robbyrussell style (multi-line)
  PROMPT='%{$fg[green]%}%n%{$reset_color%}%{$fg[white]%}@%{$reset_color%}%{$fg[cyan]%}%m%{$reset_color%} %{$fg[cyan]%}$(prompt_dir)%{$reset_color%}$(git_prompt_info)
%(?:%{$fg_bold[green]%}%1{➜%} :%{$fg_bold[red]%}%1{➜%} ) '
  
  # Clear right-side prompt
  RPROMPT=""
  
else
  # ========================================
  # Fallback Configuration (no oh-my-zsh)
  # ========================================
  
  # Initialize completion system manually
  autoload -U compinit
  compinit
  
  # Load version control info for git prompt
  autoload -Uz vcs_info
  precmd_vcs_info() { vcs_info }
  precmd_functions+=( precmd_vcs_info )
  setopt prompt_subst
  zstyle ':vcs_info:git:*' formats ' (%b)'
  zstyle ':vcs_info:*' enable git
  
  # Basic prompt similar to old config
  PROMPT='%{[1;32m%}%n%{[0;37m%}@%{[0;36m%}%m%{[0;37m%} %{[0;36m%}%~%{[0;37m%}${vcs_info_msg_0_} %# '
  RPROMPT=""
  
fi

# ========================================
# Common Configuration (applies always)
# ========================================

# Enable Emacs keybindings (including Ctrl+R for reverse search)
bindkey -e

# History configuration
HISTFILE=~/.zsh_history
HISTSIZE=999999999
SAVEHIST=$HISTSIZE
HISTORY_IGNORE="(ls|cd|bg|fg|exit|history|h)"
setopt HIST_IGNORE_DUPS      # ignore consecutive duplicates
setopt HIST_IGNORE_SPACE     # ignore lines starting with space

# Case-insensitive (all), partial-word and then substring completion
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'

# acli completion (only if acli is installed)
if command -v acli &> /dev/null && [ -f ~/.zsh/completions/_acli ]; then
  source ~/.zsh/completions/_acli
fi

# ========================================
# Shared Configuration
# ========================================

{{ template "shell_common_interactive" }}

# Remove leftover aliases not suppressed by zstyle
unalias globurl run-help which-command 2>/dev/null
