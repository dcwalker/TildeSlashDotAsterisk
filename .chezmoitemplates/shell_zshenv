# ========================================
# Environment for zsh non-interactive + interactive shells
# ========================================

# Homebrew (macOS): eval shellenv so brew and formulae are on PATH
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# PATH additions (only add directories that exist)
[ -d "$HOME/.dprint/bin" ] && PATH="$HOME/.dprint/bin:$PATH"
[ -d "/usr/local/bin" ] && PATH="/usr/local/bin:$PATH"
[ -d "$HOME/Library/Python/3.9/bin" ] && PATH="$HOME/Library/Python/3.9/bin:$PATH"
[ -d "$HOME/.local/bin" ] && PATH="$HOME/.local/bin:$PATH"
[ -d "$HOME/bin" ] && PATH="$HOME/bin:$PATH"
[ -d "$HOME/scripts" ] && PATH="$HOME/scripts:$PATH"
# Skill script dirs (cursor, claude, codex) so scripts in skills/*/scripts are executable by name
for _skill_scripts in "$HOME/.cursor/skills/"*/scripts "$HOME/.claude/skills/"*/scripts "$HOME/.codex/skills/"*/scripts; do
  [ -d "$_skill_scripts" ] && PATH="$_skill_scripts:$PATH"
done
unset _skill_scripts
export PATH

# Load secrets
[ -f ~/.env.secrets ] && source ~/.env.secrets
