#!/bin/bash

# Install Python packages required by chezmoi-managed scripts.
# chezmoi re-runs this script whenever requirements.txt changes.
# requirements.txt hash: {{ include "exact_scripts/requirements.txt" | sha256sum }}

set -euo pipefail

if ! command -v pip3 &> /dev/null; then
    echo "pip3 is not available. Skipping Python package installation."
    exit 0
fi

REQUIREMENTS="{{ .chezmoi.sourceDir }}/exact_scripts/requirements.txt"

PIP_FLAGS="--user -q -r $REQUIREMENTS"
if python3 -c "import sys, pathlib; sys.exit(0 if (pathlib.Path(sys.prefix) / 'EXTERNALLY-MANAGED').exists() else 1)" 2>/dev/null; then
    PIP_FLAGS="$PIP_FLAGS --break-system-packages"
fi

echo "Installing Python packages from requirements.txt..."
pip3 install $PIP_FLAGS
echo "Python packages installed successfully."
